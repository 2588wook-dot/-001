{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "An architectural/interior portfolio project.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": ["interior", "construction", "remodeling"]
        },
        "location": {
          "type": "string"
        },
        "area": {
          "type": "string"
        },
        "period": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "thumbnail": {
          "type": "string"
        },
        "images": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "createdAt": {
          "type": "string"
        },
        "featured": {
          "type": "boolean"
        },
        "position": {
          "type": "integer"
        }
      },
      "required": ["id", "title", "category", "location", "area", "period", "description", "thumbnail", "images", "createdAt", "featured", "position"]
    }
  },
  "firestore": {
    "projects": {
      "schema": "Project",
      "description": "Collection of architectural portfolio projects"
    }
  }
}
