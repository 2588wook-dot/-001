rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { 
      return request.resource.data; 
    }
    
    function existing() { 
      return resource.data; 
    }

    function isValidProject(p) {
      return p.keys().hasAll(['id', 'title', 'category', 'location', 'area', 'period', 'description', 'thumbnail', 'images', 'createdAt', 'featured', 'position']) &&
             p.keys().size() == 12 &&
             p.id is string &&
             p.title is string &&
             p.category is string && (p.category == 'interior' || p.category == 'construction' || p.category == 'remodeling') &&
             p.location is string &&
             p.area is string &&
             p.period is string &&
             p.description is string &&
             p.thumbnail is string &&
             p.images is list &&
             p.createdAt != null &&
             p.featured is bool &&
             p.position is int;
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if isValidId(projectId) && isValidProject(incoming()) && incoming().id == projectId;
      allow update: if isValidId(projectId) && isValidProject(incoming()) && incoming().id == projectId;
      allow delete: if isValidId(projectId);
    }
  }
}
